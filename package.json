{
  "name": "agentdesk",
  "version": "0.1.0",
  "description": "AgentDesk Windows desktop agent orchestration app",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "start": "electron .",
    "build": "vite build --config frontend/vite.config.ts",
    "dist": "npm run build && electron-builder --win",
    "test": "vitest run",
    "phase1:check": "npm test && npm run build",
    "phase3:check": "npm test && npm run build",
    "phase4:check": "npm test && npm run build",
    "phase5:check": "npm test && npm run build",
    "phase6:check": "npm test && npm run build",
    "phase7:check": "npm test && npm run build",
    "phase8:check": "npm test && npm run build",
    "phase9:check": "npm test && npm run build",
    "phase10:check": "npm test && npm run dist"
  },
  "build": {
    "appId": "com.agentdesk.app",
    "productName": "AgentDesk",
    "copyright": "AgentDesk",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "electron/**/*",
      "backend/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "npmRebuild": true
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "better-sqlite3": "^12.10.0",
    "electron-store": "^8.2.0",
    "express": "^4.21.2",
    "gpt-tokenizer": "^2.9.0",
    "iconv-lite": "^0.6.3",
    "jschardet": "^3.1.4",
    "openai": "^4.104.0",
    "uuid": "^11.1.0",
    "vite": "^6.3.5",
    "vue": "^3.5.14",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "supertest": "^7.1.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4",
    "vue-tsc": "^2.2.10"
  }
}
